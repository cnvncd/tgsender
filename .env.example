# TELEGRAM BROADCAST BOT - CONFIGURATION EXAMPLE
# ==================================================
# Copy this file to .env and fill in your values
# WARNING: DO NOT COMMIT .env FILE TO VERSION CONTROL!

# ==================================================
# CORE CREDENTIALS (REQUIRED)
# ==================================================

# Bot token from @BotFather
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Admin user IDs (comma separated) - get from @userinfobot
ADMIN_IDS=123456789,987654321

# Telegram API credentials from https://my.telegram.org
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# ==================================================
# BROADCAST SETTINGS
# ==================================================

# Delay between messages (seconds)
MESSAGE_DELAY=0.5

# Maximum delay during flood control (seconds)
MAX_MESSAGE_DELAY=30

# Progress report interval (number of messages)
PROGRESS_REPORT_INTERVAL=500

# ==================================================
# PATHS AND DIRECTORIES
# ==================================================

# Directory for Telethon sessions
SESSION_DIR=telethon_sessions

# Directory for logs
LOGS_DIR=logs

# Account names file
ACCOUNT_NAMES_FILE=account_names.json

# Directory for broadcast control
CONTROL_DIR=broadcast_control

# ==================================================
# LOGGING
# ==================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Log file name
LOG_FILE=bot.log

# ==================================================
# DATABASE (OPTIONAL)
# ==================================================

# Database URL
DATABASE_URL=sqlite:///broadcast_bot.db
